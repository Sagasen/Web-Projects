# Frontend (Vite) - aman untuk diexpose ke browser
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Backend (Vercel Serverless Functions di folder /api) - JANGAN diberi prefix VITE_
# supaya tidak ikut ter-bundle ke browser. Isi di Vercel Project Settings > Environment Variables.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
