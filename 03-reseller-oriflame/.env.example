# Supabase - ambil dari Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Cloudinary - ambil dari Cloudinary Dashboard
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Nomor WhatsApp tujuan pemesanan (format 62xxx, tanpa tanda + atau spasi)
VITE_WHATSAPP_NUMBER=6281234567890

# --- Hanya untuk npm run seed (data dummy), JANGAN dipakai di kode frontend ---
# Ambil dari Supabase Dashboard > Project Settings > API > service_role key
# Key ini punya akses penuh, jangan pernah di-expose ke browser/commit ke git
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
