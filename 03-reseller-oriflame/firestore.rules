rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Produk: semua orang bisa baca, hanya admin (terautentikasi) bisa tulis
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Promo: semua orang bisa baca, hanya admin bisa tulis
    match /promos/{promoId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
